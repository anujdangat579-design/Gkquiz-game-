rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Question Bank PDFs — anyone signed in can view/download; only an
    // admin (custom claim, same as Firestore rules) can upload/replace.
    match /question-bank-pdfs/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.admin == true
        && request.resource.contentType == 'application/pdf'
        && request.resource.size < 20 * 1024 * 1024; // 20MB cap per PDF
    }

    // Everything else stays locked down by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
