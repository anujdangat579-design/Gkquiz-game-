rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Used only by the matches/{matchId} update rule: when player X writes
    // their own rawAnswers entry, make sure player Y's existing entry (if
    // any) is carried through byte-for-byte, not edited or removed.
    function _opponentAnswerUnchanged(before, after, myUid) {
      let otherUid = before.playerA.uid == myUid ? before.playerB.uid : before.playerA.uid;
      let beforeRaw = before.get('rawAnswers', {});
      let afterRaw = after.rawAnswers;
      return !(otherUid in beforeRaw) || (otherUid in afterRaw && afterRaw[otherUid] == beforeRaw[otherUid]);
    }

    // Same idea for the `flags` map (anti-cheat telemetry: tab-switch /
    // blur counts). Unlike rawAnswers, a player's own flags entry can be
    // updated more than once (counts go up during the quiz), but they can
    // never touch the opponent's entry.
    function _opponentFlagsUnchanged(before, after, myUid) {
      let otherUid = before.playerA.uid == myUid ? before.playerB.uid : before.playerA.uid;
      let beforeFlags = before.get('flags', {});
      let afterFlags = after.get('flags', {});
      return !(otherUid in beforeFlags) || (otherUid in afterFlags && afterFlags[otherUid] == beforeFlags[otherUid]);
    }

    // User profiles: readable by anyone signed in (needed for the
    // leaderboard), but a player can only ever write their own document —
    // except an admin, who can also flip moderation fields like `blocked`.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null &&
        (request.auth.uid == uid || request.auth.token.admin == true);
    }

    // Payment transactions: written only by Cloud Functions (Admin SDK
    // bypasses rules entirely). Owner can read their own for receipts;
    // admin can read across all users for dashboard stats.
    match /transactions/{transactionId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || request.auth.token.admin == true);
      allow write: if false;
    }

    // Matchmaking queue: a player can only create/delete their own entry,
    // and only once a matching transaction has been marked 'paid' by the
    // verifyPayment Cloud Function — never trust the client's own claim.
    // A blocked user (admin action) can never join the queue.
    match /queue/{entryId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.blocked != true
        && get(/databases/$(database)/documents/transactions/$(request.resource.data.transactionId)).data.status == 'paid'
        && get(/databases/$(database)/documents/transactions/$(request.resource.data.transactionId)).data.userId == request.auth.uid;
      allow read: if request.auth != null;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
      // status/matchId get flipped by the opponent's matching transaction,
      // so update is allowed for any signed-in user rather than owner-only.
      allow update: if request.auth != null;
    }

    // Matches: only the two assigned players can read their match, plus the
    // admin (monitoring). Creation must name the creator as a real
    // participant, in the pre-question state, with no scores/winner yet —
    // closing off a client forging its own "match". After that, a player
    // can NEVER write questionSet, scores, winner, status, or completedAt
    // directly: the only update a client can ever make is adding its own
    // key under `rawAnswers`, and only once (no resubmitting), without
    // touching the opponent's existing entry. `assignQuestions` and
    // `evaluateMatch` (Cloud Functions, Admin SDK) are what actually set
    // the question set and the final result — the Admin SDK bypasses these
    // rules entirely, so no explicit allow is needed for them here.
    match /matches/{matchId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.playerA.uid ||
         request.auth.uid == resource.data.playerB.uid ||
         request.auth.token.admin == true);

      allow create: if request.auth != null
        && (request.resource.data.playerA.uid == request.auth.uid || request.resource.data.playerB.uid == request.auth.uid)
        && request.resource.data.status == 'pending_questions'
        && request.resource.data.questionSet.size() == 0
        && request.resource.data.scores == {}
        && request.resource.data.winner == null;

      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.playerA.uid || request.auth.uid == resource.data.playerB.uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rawAnswers']) &&
        !(request.auth.uid in resource.data.get('rawAnswers', {})) &&
        request.resource.data.rawAnswers[request.auth.uid] is map &&
        _opponentAnswerUnchanged(resource.data, request.resource.data, request.auth.uid);

      allow update: if request.auth != null && request.auth.token.admin == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt']);

      // Anti-cheat telemetry: a player can report their own tab-switch /
      // window-blur count (never the opponent's) at any point during the
      // quiz. This is a signal for admin review only — it never affects
      // server-side scoring, which evaluateMatch computes purely from
      // rawAnswers vs. the real answer key.
      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.playerA.uid || request.auth.uid == resource.data.playerB.uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['flags']) &&
        _opponentFlagsUnchanged(resource.data, request.resource.data, request.auth.uid);
    }

    // Question Bank: contains `correctIndex` / `explanation`, so it must
    // NEVER be readable by an ordinary player — that would hand out the
    // answer key. Only an admin (question management) and Cloud Functions
    // (Admin SDK, bypasses rules — assignQuestions / evaluateMatch) ever
    // read this collection. Live matches get a pre-stripped questionSet
    // copy (no correctIndex/explanation) written into their own match doc
    // by assignQuestions instead of reading this collection directly.
    match /questions/{questionId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow create, update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Refund requests: a player can create their own, read their own, but
    // only Cloud Functions (Admin SDK, bypasses rules) can approve/reject —
    // never the client, since that's a money-movement decision.
    match /refundRequests/{requestId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || request.auth.token.admin == true);
      allow update, delete: if false;
    }

    // Competition config: entry fee, question-count options, enabled
    // categories/difficulties. Readable by any signed-in user (QuizSetup
    // needs it to show the current fee/options); only an admin can write
    // it, and only Cloud Functions (Admin SDK) treat it as the source of
    // truth for the fee actually charged — a tampered client write still
    // can't change what createOrder charges, only what the UI displays.
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Devices: best-effort multi-account detection telemetry (see
    // src/lib/device.js). Any signed-in user can upsert their own presence
    // onto a device doc (adding their own uid to linkedUids) — this is
    // low-stakes telemetry, not an access-control decision, so it doesn't
    // need the strict per-field diffing used on `matches`. Only an admin
    // can read the collection (it's a list of which accounts share a
    // device, which shouldn't be visible to ordinary players).
    match /devices/{deviceId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow create, update: if request.auth != null &&
        request.auth.uid in request.resource.data.linkedUids;
      allow delete: if false;
    }

    // Audit log: admin-readable only, written only by Cloud Functions.
    match /auditLogs/{logId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // Period leaderboards (daily/weekly/monthly): small aggregate docs
    // bumped only by the evaluateMatch Cloud Function (Admin SDK) when a
    // match completes. Readable by any signed-in user — never ranked by
    // money, only wins/accuracy/matches (see functions/index.js).
    match /leaderboardDaily/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /leaderboardWeekly/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /leaderboardMonthly/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// v2 update: scores/winner are now written exclusively by the
// `evaluateMatch` Cloud Function from the real `questions` answer key —
// see the `matches` rules above and functions/index.js. A client can only
// ever submit its own raw answers, never a score.
